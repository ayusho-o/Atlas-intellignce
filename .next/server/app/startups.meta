{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/startups/layout,_N_T_/startups/page,_N_T_/startups"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/startups/__PAGE__",
    "/startups",
    "/_index",
    "/_head"
  ]
}