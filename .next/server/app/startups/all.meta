{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/startups/layout,_N_T_/startups/all/layout,_N_T_/startups/all/page,_N_T_/startups/all"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/startups/all/__PAGE__",
    "/startups/all",
    "/startups",
    "/_index",
    "/_head"
  ]
}